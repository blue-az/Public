# Redirects for project-phoenix and bulkhead-tau-core to bulkhead-tau

# 1. Paper redirects
RedirectMatch 301 ^/project-phoenix/(generated-papers|generated-papers-src)/(.+)$ /bulkhead-tau/$1/$2
RedirectMatch 301 ^/bulkhead-tau-core/(generated-papers|generated-papers-src)/(.+)$ /bulkhead-tau/$1/$2

# 2. General redirect for other core site pages to /bulkhead-tau/
RedirectMatch 301 ^/project-phoenix(/.*)?$ /bulkhead-tau/
RedirectMatch 301 ^/bulkhead-tau-core(/.*)?$ /bulkhead-tau/

# 3. Redirect root to bulkhead-tau
RedirectMatch 301 ^/$ /bulkhead-tau/
